# ==================== DATABASE ====================
DB_HOST=localhost
DB_PORT=5432
DB_USER=borgovercelli
DB_PASSWORD=password
DB_NAME=borgovercelli

# ==================== REDIS ====================
# Host Redis (localhost per sviluppo, redis per Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Database Redis (0-15, di solito 0 per sessioni)
REDIS_DB=0

# ==================== SESSIONI ====================
# Chiave segreta per firmare i cookie di sessione
SESSION_SECRET=your-secret-key-change-in-production

# ==================== AMBIENTE ====================
NODE_ENV=development
PORT=3000

# ==================== EMAIL (NOTIFICHE) ====================
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=your-email@example.com

# ==================== NODEMAILER ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ==================== RESEND ====================
RESEND_API_KEY=your-resend-api-key

# ==================== RAILWAY (Produzione) ====================
# Uncomment per Railway deployment
# DATABASE_URL=postgresql://user:password@host:port/dbname
# REDIS_URL=redis://user:password@host:port

# ==================== OAUTH ====================
# URL base per i callback OAuth (https://tuosito.com oppure http://localhost:3000)
OAUTH_CALLBACK_BASE_URL=http://localhost:3000

